# ==============================================================================
# DocuMind Environment Variables Example Template
# ==============================================================================
# Instructions: Copy this file to a new file named '.env' and fill in the values.
# DO NOT commit the '.env' file containing real secrets to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# Django Configuration
# ------------------------------------------------------------------------------
# Security Warning: Keep the secret key used in production secret!
DJANGO_SECRET_KEY=your-django-secret-key-here-must-be-long-and-secure
# Set to True for development, False for production
DJANGO_DEBUG=True
# Comma-separated list of hosts/domain names that this Django site can serve
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Comma-separated list of CORS origins allowed to make requests to the API
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ------------------------------------------------------------------------------
# PostgreSQL Database Configuration
# ------------------------------------------------------------------------------
# Database host name (e.g. localhost, or the Azure Flexible Server FQDN)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=documind_db
DB_USER=documind_admin
DB_PASSWORD=your-secure-database-password-here
# Use 'require' or 'verify-full' for production SSL connection. Disable for local dev if not configured.
DB_SSLMODE=disable

# ------------------------------------------------------------------------------
# Azure OpenAI Service Configuration
# ------------------------------------------------------------------------------
# API Key for Azure OpenAI service instance
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
# Endpoint URI (e.g., https://your-resource-name.openai.azure.com/)
AZURE_OPENAI_ENDPOINT=https://your-openai-service.openai.azure.com/
# Azure OpenAI API version (e.g., 2024-05-13 or latest stable)
AZURE_OPENAI_API_VERSION=2024-05-13
# Deployment name for the embedding model (e.g., text-embedding-3-large)
AZURE_OPENAI_DEPLOYMENT_EMBEDDING=text-embedding-3-large
# Deployment name for the chat/generation model (e.g., gpt-4o)
AZURE_OPENAI_DEPLOYMENT_CHAT=gpt-4o

# ------------------------------------------------------------------------------
# Azure AI Search Configuration
# ------------------------------------------------------------------------------
# Endpoint URI (e.g., https://your-search-service.search.windows.net)
AZURE_SEARCH_SERVICE_ENDPOINT=https://your-search-service.search.windows.net
# Admin query/write key for index management and document ingestion
AZURE_SEARCH_ADMIN_KEY=your-azure-search-admin-key
# Default index name for document search
AZURE_SEARCH_INDEX_NAME=documind-index

# ------------------------------------------------------------------------------
# Azure Blob Storage Configuration
# ------------------------------------------------------------------------------
# Connection string for Azure Blob Storage account (used for raw document storage)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=yourstorageaccount;AccountKey=youraccountkey;EndpointSuffix=core.windows.net
# Container name inside the storage account
AZURE_STORAGE_CONTAINER_NAME=raw-documents

# ------------------------------------------------------------------------------
# Azure Key Vault Configuration (Optional for Local, Required for Prod)
# ------------------------------------------------------------------------------
# Key Vault URI (e.g., https://your-keyvault.vault.azure.net/)
AZURE_KEYVAULT_URI=https://your-keyvault.vault.azure.net/
